NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# UUID of the CarterCo workspace (public landing-form submissions are
# tagged with this value; RLS verifies it matches workspaces.owner_email
# = louis@carterco.dk). Look up via:
#   select id from workspaces where owner_email = 'louis@carterco.dk';
NEXT_PUBLIC_CARTERCO_WORKSPACE_ID=

# Claude API key — used by the lead-quiz website analyzer AND the
# scripts/lead-enrichment-v2 pipeline (Pass B Google → Haiku reranker).
# https://console.anthropic.com/settings/keys (sk-ant-…).
ANTHROPIC_API_KEY=

# Service-role Supabase key — bypasses RLS. Required by
# scripts/lead-enrichment-v2 to write to leads_to_enrich.
# Supabase dashboard → Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Jina Reader API key — used by scripts/lead-enrichment-v2 to read
# LinkedIn pages and Google SERPs at 200+ RPM (anon is ~5 RPM).
# https://jina.ai (free signup).
JINA_API_KEY=

# Persona Gmail for the lead-response testing system (scripts/test-leads).
# Enable 2FA on the account, then generate a 16-char App Password at:
#   https://myaccount.google.com/apppasswords
PERSONA_GMAIL_ADDRESS=
PERSONA_GMAIL_APP_PWD=

# Persona identity used by scripts/test-leads/auto_submit.py to fill forms.
# Should be a believable real-looking person — same name as the Gmail account.
PERSONA_FULL_NAME=
PERSONA_FIRST_NAME=
PERSONA_LAST_NAME=
PERSONA_PHONE=                # E.164, e.g. +4520304050 (Danish prepaid SIM ideal)
PERSONA_COMPANY=              # optional — what to put when forms ask for company
